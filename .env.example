# --- SENTINEL 2.0 DEPLOYMENT CONFIG (PROD-READY) ---

# [IMPORTANT] Gemini AI Engine (For Threat Correlation)
# Used by both backend health checks and frontend research engine.
GEMINI_API_KEY=

# [IMPORTANT] Threat Intelligence Feeds (For Live Telemetry)
VIRUSTOTAL_API_KEY=
SHODAN_API_KEY=
ABUSEIPDB_API_KEY=
OTX_API_KEY=

# [IMPORTANT] Firebase Auth & Audit History
# Copy these values exactly from your 'firebase-applet-config.json'
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_DATABASE_ID=(default)

# --- SYSTEM SETTINGS ---
NODE_ENV=production
PORT=3000
