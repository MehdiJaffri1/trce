{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user basic information and preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "SearchRecord": {
      "title": "Search Record",
      "description": "History of IOC searches performed by users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["ip", "domain", "hash", "cve", "campaign"] },
        "value": { "type": "string" },
        "threatLevel": { "type": "string" },
        "confidence": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "value"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/searches/{searchId}": {
      "schema": "SearchRecord",
      "description": "History of threat searches"
    }
  }
}
